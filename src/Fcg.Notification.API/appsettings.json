{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "MassTransit": "Information",
        "System": "Warning"
      }
    },
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] [{Application}] {Message:lj}{NewLine}{Exception}"
        }
      }
    ],
    "Properties": {
      "Application": "NotificationAPI"
    }
  },
  "RabbitMqSettings": {
    "Host": "",
    "Port": "5672",
    "Username": "",
    "Password": "",
    "NotificationUserCreatedQueue": "",
    "NotificationPaymentFailedQueue": "",
    "NotificationPaymentProcessedQueue": "",
    "NotificationDeliveryFailedQueue": ""
  },
  "Redis": {
    "Host": "",
    "Port": "6379",
    "Password": "",
    "InstanceName": "FiapCloudGames:",
    "ExpirationInDays": 3
  }
}

